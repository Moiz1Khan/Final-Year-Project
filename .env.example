# Synq Voice Agent - Production API Keys
# Copy to .env and add your keys

# OpenAI (required for API mode)
OPENAI_API_KEY=sk-...

# ElevenLabs (for low-latency TTS - like professional voice agents)
ELEVENLABS_API_KEY=

# Google OAuth — Calendar + Gmail + "Sign in with Google" on the web console
# 1) Create OAuth client (type "Web application" recommended) in Google Cloud Console
# 2) Authorized redirect URI: http://127.0.0.1:8765/auth/google/callback (adjust host/port if needed)
# 3) Download JSON and set one of:
SYNQ_GOOGLE_OAUTH_CLIENT_SECRETS_PATH=
# Or reuse the same file for server token refresh + OAuth login:
GOOGLE_CLIENT_SECRETS_PATH=
# Optional override (default: http://127.0.0.1:8765/auth/google/callback)
# SYNQ_GOOGLE_OAUTH_REDIRECT_URI=
# Legacy: where to store a shared token file when not using per-user web login (defaults to data/google_token.json)
GOOGLE_TOKEN_PATH=

# Multi-user console + JWT API (synq_cloud voice mode)
# SYNQ_SESSION_SECRET=long-random-string-for-web-cookies
# SYNQ_JWT_SECRET=       # Strong secret for JWT signing (or auto: data/.synq_jwt_secret)
# SYNQ_ENCRYPTION_KEY=   # Fernet key; if unset, auto-generated in data/.synq_encryption_key
# SYNQ_ACTIVE_USER_ID=1  # CLI override for which user's row is used for Google paths (local mode)

# Server-only (required on the machine running run_web.py for shared AI)
# OPENAI_API_KEY=        # Used by POST /api/v1/chat and /api/v1/transcribe
# ELEVENLABS_API_KEY=    # Used by POST /api/v1/tts
# ELEVENLABS_VOICE_ID=   # Server TTS voice

# Optional
# PICOVOICE_ACCESS_KEY=  # For Porcupine wake word
